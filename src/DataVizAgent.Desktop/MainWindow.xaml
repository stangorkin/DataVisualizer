<Window x:Class="DataVizAgent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:blazor="clr-namespace:Microsoft.AspNetCore.Components.WebView.Wpf;assembly=Microsoft.AspNetCore.Components.WebView.Wpf"
        xmlns:components="clr-namespace:DataVizAgent.Components;assembly=DataVizAgent.UI"
        Title="DataViz Agent"
        Width="1600"
        Height="1000"
        WindowStartupLocation="CenterScreen">
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New" Executed="OnNewSession" />
        <CommandBinding Command="ApplicationCommands.Open" Executed="OnOpenSession" />
        <CommandBinding Command="ApplicationCommands.Save" Executed="OnSaveSession" />
        <CommandBinding Command="ApplicationCommands.Print" Executed="OnPrint" />
    </Window.CommandBindings>
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New Session" Command="ApplicationCommands.New" InputGestureText="Ctrl+N" />
                <MenuItem Header="_Open Session…" Command="ApplicationCommands.Open" InputGestureText="Ctrl+O" />
                <MenuItem Header="_Save Session…" Command="ApplicationCommands.Save" InputGestureText="Ctrl+S" />
                <Separator />
                <MenuItem Header="_Print Page…" Command="ApplicationCommands.Print" InputGestureText="Ctrl+P" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
        </Menu>
        <blazor:BlazorWebView HostPage="wwwroot\index.html"
                              Services="{DynamicResource services}"
                              StartPath="/">
            <blazor:BlazorWebView.RootComponents>
                <!-- Mount the router (not Home directly) so the desktop renders through
                     MainLayout exactly like the web host: app header + full-height shell. -->
                <blazor:RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
            </blazor:BlazorWebView.RootComponents>
        </blazor:BlazorWebView>
    </DockPanel>
</Window>